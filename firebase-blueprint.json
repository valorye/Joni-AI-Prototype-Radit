{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Stores user fitness profile, goals, and metrics.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "fitnessGoal": { "type": "string", "enum": ["bodybuilding", "health", "endurance", "powerlifting", "recovery"] },
        "experienceLevel": { "type": "string", "enum": ["beginner", "intermediate", "advanced"] },
        "currentWeight": { "type": "number" },
        "targetWeight": { "type": "number" },
        "height": { "type": "number" },
        "gender": { "type": "string" },
        "availableEquipment": { "type": "array", "items": { "type": "string" } },
        "dailyStreak": { "type": "integer" },
        "caloriesTarget": { "type": "integer" },
        "activeMinutesTarget": { "type": "integer" },
        "stepsTarget": { "type": "integer" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "email"]
    },
    "WorkoutPlan": {
      "title": "Workout Plan",
      "description": "A personalized workout routine generated by AI.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "type": { "type": "string" },
        "description": { "type": "string" },
        "exercises": {
          "type": "array",
          "items": {
            "$ref": "Exercise"
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Exercise": {
      "title": "Exercise",
      "description": "Individual exercise details.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "sets": { "type": "integer" },
        "reps": { "type": "string" },
        "rest": { "type": "string" },
        "targetMuscle": { "type": "string" },
        "equipmentReq": { "type": "string" }
      }
    },
    "ProgressLog": {
      "title": "Progress Log",
      "description": "Daily workout logs and metrics.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "caloriesBurned": { "type": "integer" },
        "activeMinutes": { "type": "integer" },
        "steps": { "type": "integer" },
        "completedWorkouts": { "type": "array", "items": { "type": "string" } }
      }
    },
    "ChatMessage": {
      "title": "Chat Message",
      "description": "Messages for the AI Coach.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "model"] },
        "content": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "imageUrl": { "type": "string" }
      }
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile data."
    },
    "/users/{userId}/plans/{planId}": {
      "schema": "WorkoutPlan",
      "description": "User workout plans."
    },
    "/users/{userId}/logs/{logId}": {
      "schema": "ProgressLog",
      "description": "Daily progress logs."
    },
    "/users/{userId}/chats/{messageId}": {
      "schema": "ChatMessage",
      "description": "AI Coach chat history."
    }
  }
}
